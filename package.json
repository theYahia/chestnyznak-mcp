{
  "name": "@theyahia/chestnyznak-mcp",
  "version": "1.2.0",
  "description": "MCP server for Chestniy ZNAK — product marking verification, CRPT (Russia)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "chestnyznak-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "skills",
    "smithery.yaml",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/index.ts --http",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.1.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "mcpName": "io.github.theYahia/chestnyznak-mcp",
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "claude",
    "ai",
    "russian-api",
    "chestniy-znak",
    "chestnyznak",
    "marking",
    "product-verification",
    "crpt",
    "streamable-http",
    "api",
    "typescript",
    "compliance"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/theYahia/chestnyznak-mcp.git"
  },
  "author": "theYahia (https://github.com/theYahia)"
}
